{
  "name": "@okina/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute okina --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute okina --remote --file=./schema.sql",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@okina/market-data": "workspace:*",
    "@okina/strategy": "workspace:*",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "typescript": "^5.5.4",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
